APP_NAME=Inspectra
APP_ENV=development

API_PORT=8081
UI_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

DATABASE_URL=postgresql+psycopg://inspectra:inspectra@db:5432/inspectra
REDIS_URL=redis://redis:6379/0

LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4.1-mini
LLM_VERIFY_SSL=true
REQUEST_TIMEOUT_SEC=60
LLM_MAX_RETRIES=3
PUBLISH_MAX_RETRIES=3

ENCRYPTION_KEY=replace-with-a-long-random-secret
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token
WEBHOOK_SHARED_SECRET=replace-with-a-long-random-webhook-secret

DEFAULT_MAX_ITERATIONS=3
RECHECK_ENABLED_DEFAULT=true

JIRA_ENABLED=true
GITLAB_ENABLED=true
CONFLUENCE_ENABLED=true

UI_DEFAULT_LOCALE=en
UI_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:4173,http://localhost:5173